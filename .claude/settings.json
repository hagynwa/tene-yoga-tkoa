      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git init)",
      "Bash(git config:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git revert:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(node:*)",
      "Bash(tsc:*)",
      "Bash(tsx:*)",
      "Bash(vite:*)",
      "Bash(next:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(playwright:*)",
      "Bash(cypress:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(type:*)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Location)",
      "PowerShell(Set-Location:*)",
      "PowerShell(New-Item:*)",
      "PowerShell(Copy-Item:*)",
      "PowerShell(Move-Item:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Get-Command:*)",
      "PowerShell(Get-Process:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr *)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -f:*)",
      "Bash(sudo rm:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -x:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout --:*)",
      "Bash(git restore --staged:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref -d:*)",
      "Bash(format:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs.*:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(chmod -R 777:*)",
      "Bash(chown -R:*)",
      "Bash(sudo:*)",
      "PowerShell(Remove-Item -Recurse:*)",
      "PowerShell(Remove-Item -Force -Recurse:*)",
      "PowerShell(Remove-Item -Recurse -Force:*)",
      "PowerShell(rm -Recurse:*)",
      "PowerShell(rd /s:*)",
      "PowerShell(rmdir /s:*)",
      "PowerShell(Format-Volume:*)",
      "PowerShell(Clear-Disk:*)",
      "PowerShell(Remove-Partition:*)",
      "PowerShell(Reset-ComputerMachinePassword:*)",
      "PowerShell(Stop-Computer:*)",
      "PowerShell(Restart-Computer:*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true
  }
